# Generate a strong secret:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Supabase → Project Settings → Database → Connection string (Session pooler, port 5432)
# Replace [YOUR-DATABASE-PASSWORD] with your database password.
DATABASE_URL=postgres://postgres.xxxxxx:[YOUR-DATABASE-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
